---
import '../styles/global.css';
import { site } from '../data/portfolio';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.fullName} — ${site.title}`,
  description = `${site.fullName} — ${site.title} ${site.tagline}`,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0f1419" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&f[]=jetbrains-mono@400,500&display=swap"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://sovatha.dev" />

    <title>{title}</title>

    <!-- Mark the body as loaded after first paint so fade-ups trigger -->
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        requestAnimationFrame(() => document.body.classList.add('is-loaded'));
      });
    </script>
  </head>
  <body class="bg-[var(--color-navy)] text-[var(--color-slate-dark)] antialiased">
    <slot />
  </body>
</html>
