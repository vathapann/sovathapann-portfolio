---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

if (posts.length === 0) return;

const [featured, ...rest] = posts;
---

<section
  id="blog"
  class="mx-auto max-w-3xl py-16 sm:py-20"
  aria-labelledby="blog-heading"
>
  <h2 id="blog-heading" class="section-heading" data-num="06">
    Blog
  </h2>

  <!-- Featured post -->
  <a
    href={`/blog/${featured.id}`}
    class="group relative block rounded-lg border border-navy-lighter bg-navy-light p-6 transition-all duration-200 hover:border-mint/40 hover:bg-navy-lighter"
  >
    <span class="mb-3 inline-block font-mono text-[11px] tracking-widest uppercase text-mint border border-mint/30 rounded px-2 py-0.5">
      Latest post
    </span>
    <p class="font-mono text-xs text-slate-darkest tracking-widest mb-2">
      {featured.data.date}
    </p>
    <h3 class="text-xl font-semibold text-slate-lightest group-hover:text-mint transition-colors duration-200 leading-snug mb-3">
      {featured.data.title}
    </h3>
    {featured.data.excerpt && (
      <p class="text-sm text-slate-dark leading-relaxed mb-4">
        {featured.data.excerpt}
      </p>
    )}
    <div class="flex items-center justify-between gap-4">
      {featured.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {featured.data.tags.map((tag) => (
            <span class="font-mono text-[11px] px-2 py-0.5 rounded border border-navy-lighter text-slate-darkest">
              {tag}
            </span>
          ))}
        </div>
      )}
      <svg
        class="shrink-0 text-slate-darkest transition-transform duration-200 group-hover:translate-x-1 group-hover:text-mint"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </div>
  </a>

  <!-- Remaining posts -->
  {rest.length > 0 && (
    <ul class="mt-4 divide-y divide-navy-lighter">
      {rest.map((post) => (
        <li>
          <a
            href={`/blog/${post.id}`}
            class="group flex items-center justify-between gap-6 py-4 transition-colors duration-200 hover:text-slate-lightest"
          >
            <div class="min-w-0">
              <p class="font-mono text-xs text-slate-darkest tracking-widest mb-0.5">
                {post.data.date}
              </p>
              <h3 class="text-sm font-medium text-slate-light group-hover:text-mint transition-colors duration-200 truncate">
                {post.data.title}
              </h3>
            </div>
            <svg
              class="shrink-0 text-slate-darkest transition-transform duration-200 group-hover:translate-x-1 group-hover:text-mint"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
        </li>
      ))}
    </ul>
  )}

  <div class="mt-8">
    <a href="/blog" class="btn-ghost text-sm">
      View all posts
    </a>
  </div>
</section>
