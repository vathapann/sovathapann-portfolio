---
import { site, hero, navLinks } from '../data/portfolio';
---

<aside
  class="lg:fixed lg:top-0 lg:left-0 lg:flex lg:h-screen lg:w-1/3 lg:flex-col lg:justify-between lg:px-10 lg:py-20 xl:px-16 xl:py-24"
>
  <div>
    <h1
      class="fade-up text-[clamp(2.5rem,8vw,4.5rem)] font-bold leading-none tracking-tight text-[var(--color-slate-lightest)]"
      data-delay="1"
    >
      {site.fullName}.
    </h1>
    <h2
      class="fade-up mt-3 text-xl font-medium tracking-tight text-[var(--color-slate-light)] sm:text-2xl"
      data-delay="2"
    >
      {site.title}
    </h2>
    <p
      class="fade-up mt-4 max-w-xs text-base text-[var(--color-slate-dark)]"
      data-delay="3"
    >
      {hero.tagline}
    </p>

    <nav class="fade-up mt-16 hidden lg:block" aria-label="In-page" data-delay="4">
      <ul class="space-y-4">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="nav-link group inline-flex items-center gap-4 font-mono text-xs uppercase tracking-widest text-[var(--color-slate-dark)] transition-colors duration-200 hover:text-[var(--color-slate-lightest)] focus:text-[var(--color-slate-lightest)]"
              >
                <span
                  class="nav-indicator h-px w-8 bg-[var(--color-slate-dark)] transition-all duration-200 group-hover:w-16 group-hover:bg-[var(--color-slate-lightest)] group-focus:w-16 group-focus:bg-[var(--color-slate-lightest)]"
                ></span>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <ul
    class="fade-up mt-12 flex items-center gap-5 text-[var(--color-slate-dark)] lg:mt-0"
    data-delay="5"
    aria-label="Social links"
  >
    <li>
      <a
        href={site.social.github}
        aria-label="GitHub"
        target="_blank"
        rel="noreferrer noopener"
        class="block transition-colors duration-200 hover:text-[var(--color-mint)] focus:text-[var(--color-mint)]"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
          />
        </svg>
      </a>
    </li>
    <li>
      <a
        href={site.social.linkedin}
        aria-label="LinkedIn"
        target="_blank"
        rel="noreferrer noopener"
        class="block transition-colors duration-200 hover:text-[var(--color-mint)] focus:text-[var(--color-mint)]"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          />
        </svg>
      </a>
    </li>
    <li>
      <a
        href={site.social.email}
        aria-label="Email"
        class="block transition-colors duration-200 hover:text-[var(--color-mint)] focus:text-[var(--color-mint)]"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
          <polyline points="22,6 12,13 2,6" />
        </svg>
      </a>
    </li>
    <li>
      <a
        href={site.resumeUrl}
        aria-label="Resume PDF"
        target="_blank"
        rel="noreferrer noopener"
        class="block transition-colors duration-200 hover:text-[var(--color-mint)] focus:text-[var(--color-mint)]"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
          <polyline points="14 2 14 8 20 8" />
          <line x1="9" y1="13" x2="15" y2="13" />
          <line x1="9" y1="17" x2="15" y2="17" />
        </svg>
      </a>
    </li>
  </ul>
</aside>

<script>
  // Update sidebar nav active-state based on the section currently in view.
  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const navAnchors = document.querySelectorAll<HTMLAnchorElement>('.nav-link');

  if (sections.length && navAnchors.length && 'IntersectionObserver' in window) {
    const setActive = (id: string) => {
      navAnchors.forEach((a) => {
        const isActive = a.getAttribute('href') === `#${id}`;
        const indicator = a.querySelector<HTMLSpanElement>('.nav-indicator');
        a.classList.toggle('text-[var(--color-slate-lightest)]', isActive);
        if (indicator) {
          indicator.classList.toggle('w-16', isActive);
          indicator.classList.toggle('bg-[var(--color-slate-lightest)]', isActive);
        }
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) setActive(entry.target.id);
        });
      },
      { rootMargin: '-40% 0px -40% 0px', threshold: 0 }
    );

    sections.forEach((s) => observer.observe(s));
  }
</script>
