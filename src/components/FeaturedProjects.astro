---
import { featuredProjects } from "../data/portfolio";
---

<section
  id="projects"
  class="mx-auto max-w-3xl py-16 sm:py-20"
  aria-labelledby="projects-heading"
>
  <h2 id="projects-heading" class="section-heading" data-num="05">
    Things I've built
  </h2>

  <ul class="space-y-24 lg:space-y-32">
    {
      featuredProjects.map((project, idx) => {
        const isReverse = idx % 2 !== 0;
        const isShowcase = project.variant === "showcase";
        const primaryHref = project.external || project.github || "#";
        const projectImages = project.images?.length
          ? project.images
          : [{ src: project.image, alt: project.imageAlt }];
        const hasMultipleImages = projectImages.length > 1;

        return (
          <li
            class:list={[
              "group relative grid grid-cols-12 gap-y-4 lg:gap-x-4",
              isShowcase &&
                "gap-y-5 rounded bg-[var(--color-navy-light)] p-4 ring-1 ring-[var(--color-navy-lighter)]/60 sm:p-5",
            ]}
          >
            <div
              data-project-preview
              data-project-slideshow={hasMultipleImages ? "" : undefined}
              data-project-variant={isShowcase ? "showcase" : "default"}
              class:list={[
                "project-image relative overflow-hidden bg-[var(--color-navy-light)] transition-transform duration-300",
                isShowcase
                  ? "col-span-12 rounded bg-[var(--color-navy-deep)] ring-1 ring-[var(--color-navy-lighter)]/60"
                  : [
                      "col-span-12 rounded lg:row-start-1",
                      isReverse
                        ? "lg:col-start-1 lg:col-end-9"
                        : "lg:col-start-5 lg:col-end-13",
                    ],
              ]}
            >
              <button
                type="button"
                class="block w-full cursor-zoom-in text-left"
                aria-label={`Preview image for ${project.title}`}
                data-preview-open
              >
                <div class="relative aspect-[16/10]">
                  {projectImages.map((image, imageIdx) => (
                    <img
                      src={image.src}
                      alt={image.alt}
                      loading="lazy"
                      width="1600"
                      height="1000"
                      data-slide-image
                      data-preview-src={image.src}
                      data-preview-alt={image.alt}
                      data-preview-title={project.title}
                      aria-hidden={imageIdx === 0 ? "false" : "true"}
                      class:list={[
                        "absolute inset-0 h-full w-full object-center transition-all duration-300",
                        isShowcase
                          ? "object-contain"
                          : "object-cover grayscale",
                        imageIdx === 0
                          ? isShowcase
                            ? "opacity-100"
                            : "opacity-80"
                          : "opacity-0",
                      ]}
                    />
                  ))}
                </div>
              </button>

              {hasMultipleImages && (
                <>
                  <button
                    type="button"
                    class="absolute top-1/2 left-3 z-20 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded bg-[var(--color-navy-deep)]/80 text-[var(--color-slate-lightest)] ring-1 ring-[var(--color-navy-lighter)] transition-colors duration-200 hover:text-[var(--color-mint)] focus:text-[var(--color-mint)]"
                    aria-label={`Previous image for ${project.title}`}
                    data-slide-action="prev"
                  >
                    <svg
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="m15 18-6-6 6-6" />
                    </svg>
                  </button>

                  <button
                    type="button"
                    class="absolute top-1/2 right-3 z-20 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded bg-[var(--color-navy-deep)]/80 text-[var(--color-slate-lightest)] ring-1 ring-[var(--color-navy-lighter)] transition-colors duration-200 hover:text-[var(--color-mint)] focus:text-[var(--color-mint)]"
                    aria-label={`Next image for ${project.title}`}
                    data-slide-action="next"
                  >
                    <svg
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="m9 18 6-6-6-6" />
                    </svg>
                  </button>

                  <div
                    class="absolute bottom-3 left-1/2 z-20 flex -translate-x-1/2 gap-2"
                    aria-label={`${project.title} image slides`}
                  >
                    {projectImages.map((_, imageIdx) => (
                      <button
                        type="button"
                        class:list={[
                          "h-2.5 w-2.5 rounded-full ring-1 ring-[var(--color-slate-lightest)]/70 transition-colors duration-200",
                          imageIdx === 0
                            ? "bg-[var(--color-mint)]"
                            : "bg-[var(--color-navy-deep)]/70",
                        ]}
                        aria-label={`Show image ${imageIdx + 1} for ${project.title}`}
                        aria-current={imageIdx === 0 ? "true" : "false"}
                        data-slide-dot
                      />
                    ))}
                  </div>
                </>
              )}
            </div>

            <div
              class:list={[
                "relative z-10 col-span-12",
                isShowcase
                  ? "p-0"
                  : [
                      "lg:row-start-1 lg:self-center",
                      isReverse
                        ? "lg:col-start-7 lg:col-end-13 lg:text-right"
                        : "lg:col-start-1 lg:col-end-7",
                    ],
              ]}
            >
              <p class="font-mono text-xs text-[var(--color-mint)]">
                Featured project
              </p>
              <h3
                class:list={[
                  "mt-2 font-semibold tracking-tight text-[var(--color-slate-lightest)]",
                  isShowcase ? "text-2xl sm:text-3xl" : "text-2xl",
                ]}
              >
                <a
                  href={primaryHref}
                  target="_blank"
                  rel="noreferrer noopener"
                  class="transition-colors duration-200 hover:text-[var(--color-mint)]"
                >
                  {project.title}
                </a>
              </h3>

              <div
                class:list={[
                  "mt-4 rounded p-6 text-sm leading-relaxed text-[var(--color-slate-dark)] shadow-lg ring-1 ring-[var(--color-navy-lighter)]/40",
                  isShowcase
                    ? "bg-[var(--color-navy-deep)]/78 backdrop-blur"
                    : "bg-[var(--color-navy-light)]",
                ]}
              >
                <p set:html={project.description} />
              </div>

              <ul
                class:list={[
                  "mt-4 flex flex-wrap gap-x-4 gap-y-2 font-mono text-xs text-[var(--color-slate-dark)]",
                  isReverse && !isShowcase && "lg:justify-end",
                ]}
                aria-label="Technologies used"
              >
                {project.tech.map((t) => (
                  <li>{t}</li>
                ))}
              </ul>

              <div
                class:list={[
                  "mt-4 flex items-center gap-5 text-[var(--color-slate-lightest)]",
                  isReverse && !isShowcase && "lg:justify-end",
                ]}
              >
                {project.github && (
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noreferrer noopener"
                    aria-label={`${project.title} source on GitHub`}
                    class="transition-colors duration-200 hover:text-[var(--color-mint)]"
                  >
                    <svg
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                    </svg>
                  </a>
                )}
                {project.external && (
                  <a
                    href={project.external}
                    target="_blank"
                    rel="noreferrer noopener"
                    aria-label={`${project.title} live link`}
                    class="transition-colors duration-200 hover:text-[var(--color-mint)]"
                  >
                    <svg
                      width="22"
                      height="22"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                      <polyline points="15 3 21 3 21 9" />
                      <line x1="10" y1="14" x2="21" y2="3" />
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </li>
        );
      })
    }
  </ul>
</section>

<div
  id="project-image-preview"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-[var(--color-navy-deep)]/90 p-4 backdrop-blur-sm sm:p-6"
  role="dialog"
  aria-modal="true"
  aria-labelledby="project-image-preview-title"
>
  <button
    type="button"
    class="absolute inset-0 cursor-zoom-out"
    aria-label="Close image preview"
    data-preview-close></button>

  <div class="relative z-10 max-h-full w-full max-w-6xl">
    <div class="mb-3 flex items-center justify-between gap-4">
      <p
        id="project-image-preview-title"
        class="font-mono text-sm text-[var(--color-slate-lightest)]"
        data-preview-title
      >
      </p>
      <button
        type="button"
        class="flex h-10 w-10 shrink-0 items-center justify-center rounded bg-[var(--color-navy-light)] text-[var(--color-slate-lightest)] ring-1 ring-[var(--color-navy-lighter)] transition-colors duration-200 hover:text-[var(--color-mint)] focus:text-[var(--color-mint)]"
        aria-label="Close image preview"
        data-preview-close
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>

    <img
      src=""
      alt=""
      class="max-h-[82vh] w-full rounded bg-[var(--color-navy-light)] object-contain ring-1 ring-[var(--color-navy-lighter)]"
      data-preview-image
    />
  </div>
</div>

<script>
  const previewModal = document.querySelector<HTMLElement>(
    "#project-image-preview",
  );
  const previewImage = previewModal?.querySelector<HTMLImageElement>(
    "[data-preview-image]",
  );
  const previewTitle = previewModal?.querySelector<HTMLElement>(
    "[data-preview-title]",
  );
  let lastPreviewTrigger: HTMLElement | null = null;

  const openPreview = (trigger: HTMLElement, image: HTMLImageElement) => {
    if (!previewModal || !previewImage || !previewTitle) return;

    const src = image.dataset.previewSrc || image.currentSrc || image.src;
    const alt = image.dataset.previewAlt || image.alt;
    const title = image.dataset.previewTitle || alt;

    lastPreviewTrigger = trigger;
    previewImage.src = src;
    previewImage.alt = alt;
    previewTitle.textContent = title;
    previewModal.classList.remove("hidden");
    previewModal.classList.add("flex");
    document.body.style.overflow = "hidden";
    previewModal
      .querySelector<HTMLButtonElement>("[data-preview-close]")
      ?.focus();
  };

  const closePreview = () => {
    if (!previewModal || !previewImage) return;

    previewModal.classList.add("hidden");
    previewModal.classList.remove("flex");
    previewImage.src = "";
    document.body.style.overflow = "";
    lastPreviewTrigger?.focus();
  };

  previewModal
    ?.querySelectorAll<HTMLButtonElement>("[data-preview-close]")
    .forEach((button) => {
      button.addEventListener("click", closePreview);
    });

  document.addEventListener("keydown", (event) => {
    if (
      event.key === "Escape" &&
      previewModal &&
      !previewModal.classList.contains("hidden")
    ) {
      closePreview();
    }
  });

  document
    .querySelectorAll<HTMLElement>("[data-project-preview]")
    .forEach((projectPreview) => {
      const previewButton = projectPreview.querySelector<HTMLButtonElement>(
        "[data-preview-open]",
      );

      previewButton?.addEventListener("click", () => {
        const activeImage =
          projectPreview.querySelector<HTMLImageElement>(
            '[data-slide-image][aria-hidden="false"]',
          ) ||
          projectPreview.querySelector<HTMLImageElement>("[data-slide-image]");

        if (activeImage) openPreview(previewButton, activeImage);
      });
    });

  const slideshows = document.querySelectorAll<HTMLElement>(
    "[data-project-slideshow]",
  );

  slideshows.forEach((slideshow) => {
    const images = Array.from(
      slideshow.querySelectorAll<HTMLImageElement>("[data-slide-image]"),
    );
    const dots = Array.from(
      slideshow.querySelectorAll<HTMLButtonElement>("[data-slide-dot]"),
    );
    const previous = slideshow.querySelector<HTMLButtonElement>(
      '[data-slide-action="prev"]',
    );
    const next = slideshow.querySelector<HTMLButtonElement>(
      '[data-slide-action="next"]',
    );
    const activeOpacity =
      slideshow.dataset.projectVariant === "showcase"
        ? "opacity-100"
        : "opacity-80";
    let activeIndex = 0;

    const setActiveImage = (nextIndex: number) => {
      activeIndex = (nextIndex + images.length) % images.length;

      images.forEach((image, imageIndex) => {
        const isActive = imageIndex === activeIndex;
        image.classList.toggle(activeOpacity, isActive);
        image.classList.toggle("opacity-0", !isActive);
        image.classList.toggle("grayscale", !isActive);
        image.classList.toggle("grayscale-0", isActive);
        image.setAttribute("aria-hidden", isActive ? "false" : "true");
      });

      dots.forEach((dot, dotIndex) => {
        const isActive = dotIndex === activeIndex;
        dot.classList.toggle("bg-[var(--color-mint)]", isActive);
        dot.classList.toggle("bg-[var(--color-navy-deep)]/70", !isActive);
        dot.setAttribute("aria-current", isActive ? "true" : "false");
      });
    };

    previous?.addEventListener("click", () => setActiveImage(activeIndex - 1));
    next?.addEventListener("click", () => setActiveImage(activeIndex + 1));
    dots.forEach((dot, dotIndex) => {
      dot.addEventListener("click", () => setActiveImage(dotIndex));
    });
  });
</script>
