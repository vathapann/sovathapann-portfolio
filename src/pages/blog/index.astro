---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<Layout
  title="Writing — Sovatha Pann"
  description="Technical writing on DevOps, homelab, and full-stack engineering."
>
  <div class="mx-auto max-w-2xl px-6 py-20 sm:px-10">
    <a
      href="/"
      class="inline-flex items-center gap-2 font-mono text-xs tracking-widest uppercase text-[var(--color-slate-dark)] hover:text-[var(--color-mint)] transition-colors duration-200 mb-16"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
       Back to portfolio
    </a>

    <h1
      class="text-4xl font-bold tracking-tight text-[var(--color-slate-lightest)] mb-2"
    >
      Blog
    </h1>
    <p class="text-[var(--color-slate-dark)] mb-16">
      Notes on DevOps, homelab, and full-stack engineering.
    </p>

    {
      posts.length === 0 ? (
        <p class="text-[var(--color-slate-dark)]">No posts yet. Check back soon.</p>
      ) : (
        <div class="space-y-12">
          {posts.map((post) => (
            <article>
              <a href={`/blog/${post.id}`} class="group block">
                <p class="font-mono text-xs text-[var(--color-mint)] tracking-widest mb-2">
                  {post.data.date}
                </p>
                <h2 class="text-xl font-semibold text-[var(--color-slate-light)] group-hover:text-[var(--color-mint)] transition-colors duration-200 mb-2">
                  {post.data.title}
                </h2>
                {post.data.excerpt && (
                  <p class="text-[var(--color-slate-dark)] text-sm leading-relaxed">
                    {post.data.excerpt}
                  </p>
                )}
                {post.data.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="font-mono text-xs px-2 py-0.5 rounded border border-[var(--color-navy-lighter)] text-[var(--color-slate-darkest)]">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            </article>
          ))}
        </div>
      )
    }
  </div>
</Layout>
