{
  "name": "sovatha-portfolio",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Personal portfolio for Sovatha — Sydney-based backend & platform engineer.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "format": "prettier --write \"**/*.{astro,ts,tsx,js,jsx,css,md}\"",
    "format:check": "prettier --check \"**/*.{astro,ts,tsx,js,jsx,css,md}\"",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types"
